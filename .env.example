# ====== Flask Core ======
SECRET_KEY=change-this-to-a-random-secret-string
FLASK_ENV=production

# ====== Database (PostgreSQL — e.g. Neon) ======
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ====== khmer-smm.com (or other) Provider API ======
PROVIDER_API_URL=https://khmer-smm.com/api/v2
PROVIDER_API_KEY=your_smm_provider_api_key_here

# ====== Markup pricing ======
DEFAULT_MARKUP_PERCENT=30

# ====== CamRapidPay (KHQR payment gateway) ======
CAMRAPID_API_KEY=your_camrapidpay_api_key_here
CAMRAPID_CREATE_URL=https://pay.camrapidpay.com/api/v1/khqr/create-payments
CAMRAPID_CHECK_URL=https://pay.camrapidpay.com/check-transaction-api

# ====== Admin bootstrap (first run only) ======
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@kairozen.local
ADMIN_PASSWORD=change-this-password

# ====== App URL (used for webhook/display links) ======
APP_BASE_URL=https://yourdomain.com
