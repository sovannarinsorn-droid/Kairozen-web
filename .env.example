# ====== Flask Core ======
SECRET_KEY=change-this-to-a-random-secret-string
FLASK_ENV=production

# ====== Database (PostgreSQL) ======
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://kairozen:password@localhost:5432/kairozen_smm

# ====== khmer-smm.com Provider API ======
PROVIDER_API_URL=https://khmer-smm.com/api/v2
PROVIDER_API_KEY=your_khmer_smm_api_key_here

# ====== Markup pricing ======
# Percentage added on top of provider price, e.g. 30 = +30%
DEFAULT_MARKUP_PERCENT=30

# ====== Bakong KHQR ======
BAKONG_ACCOUNT_ID=your_bakong_account_id@bank
BAKONG_MERCHANT_NAME=Kairozen Store
BAKONG_MERCHANT_CITY=Phnom Penh
BAKONG_API_TOKEN=your_bakong_bearer_token_here
BAKONG_API_URL=https://api-bakong.nbc.gov.kh/v1

# ====== Admin bootstrap (first run only) ======
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@kairozen.local
ADMIN_PASSWORD=change-this-password

# ====== App URL (used for callback links / display) ======
APP_BASE_URL=https://yourdomain.com
